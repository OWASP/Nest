{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "incremental": true,
    "inlineSources": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "*": ["./src/*"],
      "@e2e/*": ["__tests__/e2e/*"],
      "@mockData/*": ["__tests__/mockData/*"],
      "@unit/*": ["__tests__/unit/*"],
      "app/*": ["src/app/*"],
      "components/*": ["src/components/*"],
      "hooks/*": ["src/hooks/*"],
      "server/*": ["src/server/*"],
      "types/*": ["src/types/*"],
      "utils/*": ["src/utils/*"],
      "wrappers/*": ["src/wrappers/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2023",
    "useDefineForClassFields": true
  },
  "exclude": ["__tests__/**/*", "jest.setup.ts", "node_modules", "playwright.config.ts"],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/dev/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    "src"
  ]
}
