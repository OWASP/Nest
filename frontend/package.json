    "@react-leaflet/core": "^3.0.0",
    "@sentry/nextjs": "^10.48.0",
    "apexcharts": "^5.10.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "core-js": "^3.49.0",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "dompurify": "^3.4.0",
    "framer-motion": "^12.38.0",
    "graphql": "^16.13.2",
    "ics": "^3.11.0",
    "isomorphic-dompurify": "^3.8.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lodash": "^4.18.1",
    "markdown-it": "^14.1.1",
    "markdown-it-task-lists": "^2.1.1",
    "millify": "^6.1.0",
    "next": "^16.2.4",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
