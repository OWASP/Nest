    "globals": "^17.4.0",
    "identity-obj-proxy": "^3.0.0",
    "import-in-the-middle": "^3.0.0",
    "jest": "^30.3.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "require-in-the-middle": "^8.0.1",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "util": "^0.12.5"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "glob": "^11.1.0",
      "serialize-javascript": "^7.0.3",
      "test-exclude": "^7.0.1"
    }
  },
  "prettier": {
    "arrowParens": "always",
    "endOfLine": "lf",
    "plugins": [
      "prettier-plugin-tailwindcss"
    ],
    "printWidth": 100,
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5"
  }
}
